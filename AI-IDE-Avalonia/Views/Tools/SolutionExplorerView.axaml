<UserControl x:Class="AI_IDE_Avalonia.Views.Tools.SolutionExplorerView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="using:AI_IDE_Avalonia.ViewModels.Tools"
             xmlns:models="using:AI_IDE_Avalonia.Models"
             xmlns:controls="using:AI_IDE_Avalonia.Controls"
             mc:Ignorable="d"
             d:DesignWidth="300" d:DesignHeight="400"
             x:DataType="vm:SolutionExplorerViewModel" x:CompileBindings="True">
  <Grid RowDefinitions="Auto,*,Auto">

    <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto">

      <TextBox Grid.Column="0"
               Text="{Binding FilterText}"
               Watermark="{Binding Loc.FilterWatermark}"
               Margin="4"
               Classes="clearButton" />

      <Button Grid.Column="1"
              ToolTip.Tip="{Binding Loc.ExpandAll}"
              Click="OnExpandAll"
              Margin="0,4,2,4" Padding="6,4">
        <PathIcon Width="12" Height="12"
                  Data="M3 5 L8 10 L13 5 M3 10 L8 15 L13 10" />
      </Button>

      <Button Grid.Column="2"
              ToolTip.Tip="{Binding Loc.CollapseAll}"
              Click="OnCollapseAll"
              Margin="0,4,4,4" Padding="6,4">
        <PathIcon Width="12" Height="12"
                  Data="M3 10 L8 5 L13 10 M3 15 L8 10 L13 15" />
      </Button>

    </Grid>

    <TreeView x:Name="TreeView"
              Grid.Row="1"
              ItemsSource="{Binding FilteredNodes}"
              SelectedItems="{Binding SelectedNodes}"
              SelectionMode="Single">
      <TreeView.Styles>
        <!--
          Bind TreeViewItem.IsExpanded to TreeNode.IsExpanded so that:
          • programmatic changes (e.g. root=true, Collapse All) are reflected visually;
          • user-initiated expand/collapse is round-tripped back to the model via
            the ExpandedEvent / CollapsedEvent handlers in the code-behind.
        -->
        <Style Selector="TreeViewItem">
          <Setter Property="IsExpanded" Value="{ReflectionBinding IsExpanded}" />
        </Style>
      </TreeView.Styles>
      <TreeView.ItemTemplate>
        <TreeDataTemplate x:DataType="models:TreeNode" ItemsSource="{Binding Children}">
          <Grid>

            <!-- ── Loading placeholder row ───────────────────────────── -->
            <StackPanel Orientation="Horizontal" Spacing="5"
                        IsVisible="{Binding IsLoadingPlaceholder}"
                        Opacity="0.55">
              <ProgressBar IsIndeterminate="True"
                           Width="12" Height="12"
                           VerticalAlignment="Center" />
              <TextBlock Text="{ReflectionBinding DataContext.Loc.LoadingPlaceholder, RelativeSource={RelativeSource AncestorType=UserControl}}"
                         FontStyle="Italic"
                         VerticalAlignment="Center" />
            </StackPanel>

            <!-- ── Normal node row ───────────────────────────────────── -->
            <StackPanel Orientation="Horizontal" Spacing="5"
                        IsVisible="{Binding IsLoadingPlaceholder, Converter={x:Static BoolConverters.Not}}">

              <!--
                Folder icon + optional inline loading spinner.
                The spinner replaces the folder icon while children are being fetched
                so the row width does not change.
              -->
              <Panel Width="14" Height="14"
                     IsVisible="{Binding IsFolder}">
                <PathIcon Width="14" Height="14"
                          IsVisible="{Binding IsLoading, Converter={x:Static BoolConverters.Not}}"
                          Data="M2 6C2 4.895 2.895 4 4 4H7.172C7.702 4 8.21 4.21 8.586 4.586L9.414 5.414C9.789 5.789 10.298 6 10.828 6H12C13.105 6 14 6.895 14 8V12C14 13.105 13.105 14 12 14H4C2.895 14 2 13.105 2 12V6Z" />
                <ProgressBar Width="12" Height="12"
                             IsIndeterminate="True"
                             IsVisible="{Binding IsLoading}" />
              </Panel>

              <!-- File icon -->
              <PathIcon Width="14" Height="14"
                        IsVisible="{Binding IsFolder, Converter={x:Static BoolConverters.Not}}"
                        Data="M4 2C2.895 2 2 2.895 2 4V12C2 13.105 2.895 14 4 14H12C13.105 14 14 13.105 14 12V6.414C14 5.884 13.789 5.375 13.414 5L11 2.586C10.625 2.211 10.116 2 9.586 2H4Z" />

              <controls:HighlightTextBlock
                DisplayText="{Binding Name}"
                HighlightText="{ReflectionBinding DataContext.FilterText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                VerticalAlignment="Center" />
            </StackPanel>

          </Grid>
        </TreeDataTemplate>
      </TreeView.ItemTemplate>
    </TreeView>

    <!-- ── Status bar ──────────────────────────────────────────────────── -->
    <Border Grid.Row="2"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            Padding="6,3">
      <Grid ColumnDefinitions="*,Auto">

        <!-- Total visible node count -->
        <TextBlock Grid.Column="0"
                   VerticalAlignment="Center"
                   FontSize="11"
                   Opacity="0.65"
                   Text="{Binding ItemsSummary}" />

        <!-- Selected count — only shown when multiple nodes are selected -->
        <TextBlock Grid.Column="1"
                   VerticalAlignment="Center"
                   FontSize="11"
                   Opacity="0.65"
                   IsVisible="{Binding HasMultipleSelected}"
                   Text="{Binding SelectedSummary}" />

      </Grid>
    </Border>

  </Grid>
</UserControl>
