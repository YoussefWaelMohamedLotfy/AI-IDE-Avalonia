<Window x:Class="AI_IDE_Avalonia.Views.SplashScreenWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AI_IDE_Avalonia.ViewModels"
        x:DataType="vm:SplashScreenViewModel"
        Title="AI IDE"
        Width="480" Height="280"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        ShowInTaskbar="False"
        WindowDecorations="None"
        TransparencyLevelHint="AcrylicBlur"
        Background="{x:Null}">

  <Design.DataContext>
    <vm:SplashScreenViewModel />
  </Design.DataContext>

  <Window.Resources>
    <ExperimentalAcrylicMaterial BackgroundSource="Digger"
                                  TintColor="#1E1E2E"
                                  TintOpacity="1"
                                  FallbackColor="#1E1E2E"
                                  MaterialOpacity="0.92"
                                  x:Key="SplashAcrylic" />
  </Window.Resources>

  <Panel>
    <ExperimentalAcrylicBorder IsHitTestVisible="False"
                               Material="{StaticResource SplashAcrylic}"
                               CornerRadius="12" />

    <Border CornerRadius="12"
            BorderThickness="1"
            BorderBrush="#33FFFFFF">

      <Grid RowDefinitions="*,Auto,Auto,Auto,24"
            Margin="40,36,40,32">

        <!-- App icon + name row -->
        <StackPanel Grid.Row="0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="10">

          <Image Source="avares://AI-IDE-Avalonia/Assets/app-icon.ico"
                 Width="64" Height="64"
                 HorizontalAlignment="Center" />

          <TextBlock Text="Avalonia AI IDE"
                     FontSize="28"
                     FontWeight="Bold"
                     Foreground="White"
                     HorizontalAlignment="Center"
                     LetterSpacing="2" />

          <TextBlock Text="Intelligent Development Environment"
                     FontSize="12"
                     Foreground="#AAAACC"
                     HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Progress bar -->
        <ProgressBar Grid.Row="1"
                     Minimum="0" Maximum="100"
                     Value="{Binding Progress}"
                     Height="4"
                     CornerRadius="2"
                     Margin="0,0,0,8"
                     Foreground="#7C3AED"
                     Background="#33FFFFFF" />

        <!-- Loading message -->
        <TextBlock Grid.Row="2"
                   Text="{Binding LoadingMessage}"
                   FontSize="11"
                   Foreground="#AAAACC"
                   HorizontalAlignment="Left"
                   Margin="0,0,0,0" />

        <!-- Version / copyright footer -->
        <TextBlock Grid.Row="4"
                   Text="© 2026 AI IDE Avalonia"
                   FontSize="10"
                   Foreground="#66FFFFFF"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom" />
      </Grid>
    </Border>

    <!-- Close button in top-right corner -->
    <Button HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,10,14,0"
            Width="28" Height="28"
            Command="{Binding ExitCommand}"
            Content="✕"
            FontSize="13"
            Padding="0"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            CornerRadius="14"
            Foreground="#CCCCDD"
            Background="Transparent"
            BorderThickness="0"
            Cursor="Hand" />
  </Panel>
</Window>
