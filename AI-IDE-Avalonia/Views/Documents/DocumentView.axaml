<UserControl x:Class="AI_IDE_Avalonia.Views.Documents.DocumentView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="using:AI_IDE_Avalonia.ViewModels.Documents"
             mc:Ignorable="d"
             d:DesignWidth="500" d:DesignHeight="600"
             x:DataType="vm:DocumentViewModel" x:CompileBindings="True">

  <Grid>
    <TextBlock Text="{Binding Title}"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Opacity="0.4"
               FontSize="14" />
  </Grid>
</UserControl>
