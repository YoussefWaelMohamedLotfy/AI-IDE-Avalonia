<UserControl x:Class="AI_IDE_Avalonia.Views.Documents.DocumentView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="using:AI_IDE_Avalonia.ViewModels.Documents"
             xmlns:models="using:AI_IDE_Avalonia.Models.Documents"
             mc:Ignorable="d"
             d:DesignWidth="500" d:DesignHeight="600"
             x:DataType="vm:DocumentViewModel" x:CompileBindings="True">

  <Grid RowDefinitions="*,Auto">

    <!-- Chat message list -->
    <ScrollViewer Grid.Row="0"
                  x:Name="MessagesScroller"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  Padding="8,8,8,4">
      <ItemsControl ItemsSource="{Binding Messages}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="models:ChatMessage">
            <Grid Margin="0,3">

              <!-- User bubble — right aligned -->
              <Border IsVisible="{Binding IsUser}"
                      HorizontalAlignment="Right"
                      MaxWidth="520"
                      Background="#1E6FD9"
                      CornerRadius="14,14,4,14"
                      Padding="12,8"
                      Margin="64,0,0,0">
                <TextBlock Text="{Binding Content}"
                           TextWrapping="Wrap"
                           Foreground="White"
                           FontSize="13"
                           LineHeight="20" />
              </Border>

              <!-- Assistant bubble — left aligned -->
              <Border IsVisible="{Binding !IsUser}"
                      HorizontalAlignment="Left"
                      MaxWidth="520"
                      Background="#2D2D30"
                      CornerRadius="14,14,14,4"
                      Padding="12,8"
                      Margin="0,0,64,0">
                <StackPanel>
                  <TextBlock Text="granite4"
                             FontSize="10"
                             Opacity="0.5"
                             Margin="0,0,0,3" />
                  <TextBlock Text="{Binding Content}"
                             TextWrapping="Wrap"
                             FontSize="13"
                             LineHeight="20" />
                </StackPanel>
              </Border>

            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- Animated typing indicator shown while waiting for response -->
    <Border Grid.Row="0"
            IsVisible="{Binding IsSending}"
            VerticalAlignment="Bottom"
            HorizontalAlignment="Left"
            Background="#2D2D30"
            CornerRadius="14"
            Padding="14,11"
            Margin="16,0,0,6">
      <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">

        <StackPanel.Styles>
          <!-- Dot 1 — no delay -->
          <Style Selector="Ellipse.dot-1">
            <Style.Animations>
              <Animation Duration="0:0:0.9" Delay="0:0:0.0" IterationCount="INFINITE" Easing="SineEaseInOut">
                <KeyFrame Cue="0%">   <Setter Property="Margin" Value="0,0,0,0" /> </KeyFrame>
                <KeyFrame Cue="30%">  <Setter Property="Margin" Value="0,0,0,6" /> </KeyFrame>
                <KeyFrame Cue="60%">  <Setter Property="Margin" Value="0,0,0,0" /> </KeyFrame>
                <KeyFrame Cue="100%"> <Setter Property="Margin" Value="0,0,0,0" /> </KeyFrame>
              </Animation>
            </Style.Animations>
          </Style>

          <!-- Dot 2 — 0.15 s delay -->
          <Style Selector="Ellipse.dot-2">
            <Style.Animations>
              <Animation Duration="0:0:0.9" Delay="0:0:0.15" IterationCount="INFINITE" Easing="SineEaseInOut">
                <KeyFrame Cue="0%">   <Setter Property="Margin" Value="0,0,0,0" /> </KeyFrame>
                <KeyFrame Cue="30%">  <Setter Property="Margin" Value="0,0,0,6" /> </KeyFrame>
                <KeyFrame Cue="60%">  <Setter Property="Margin" Value="0,0,0,0" /> </KeyFrame>
                <KeyFrame Cue="100%"> <Setter Property="Margin" Value="0,0,0,0" /> </KeyFrame>
              </Animation>
            </Style.Animations>
          </Style>

          <!-- Dot 3 — 0.30 s delay -->
          <Style Selector="Ellipse.dot-3">
            <Style.Animations>
              <Animation Duration="0:0:0.9" Delay="0:0:0.30" IterationCount="INFINITE" Easing="SineEaseInOut">
                <KeyFrame Cue="0%">   <Setter Property="Margin" Value="0,0,0,0" /> </KeyFrame>
                <KeyFrame Cue="30%">  <Setter Property="Margin" Value="0,0,0,6" /> </KeyFrame>
                <KeyFrame Cue="60%">  <Setter Property="Margin" Value="0,0,0,0" /> </KeyFrame>
                <KeyFrame Cue="100%"> <Setter Property="Margin" Value="0,0,0,0" /> </KeyFrame>
              </Animation>
            </Style.Animations>
          </Style>
        </StackPanel.Styles>

        <Ellipse Classes="dot-1" Width="7" Height="7" Fill="#AAAAAA" />
        <Ellipse Classes="dot-2" Width="7" Height="7" Fill="#AAAAAA" />
        <Ellipse Classes="dot-3" Width="7" Height="7" Fill="#AAAAAA" />

      </StackPanel>
    </Border>

    <!-- Input area -->
    <Border Grid.Row="1"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            Padding="8">
      <Grid ColumnDefinitions="*,Auto">
        <TextBox Grid.Column="0"
                 x:Name="InputBox"
                 Text="{Binding InputText}"
                 Watermark="Ask granite4:latest via Ollama anything"                 IsEnabled="{Binding !IsSending}"
                 AcceptsReturn="False"
                 Padding="10,7"
                 VerticalContentAlignment="Center" />
        <Button Grid.Column="1"
                Content="Send"
                Command="{Binding SendCommand}"
                Margin="6,0,0,0"
                Padding="14,7"
                VerticalAlignment="Stretch" />
      </Grid>
    </Border>

  </Grid>
</UserControl>
