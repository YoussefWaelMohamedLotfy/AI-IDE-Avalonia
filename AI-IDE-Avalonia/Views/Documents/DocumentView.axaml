<UserControl x:Class="AI_IDE_Avalonia.Views.Documents.DocumentView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="using:AI_IDE_Avalonia.ViewModels.Documents"
             xmlns:AvalonEdit="using:AvaloniaEdit"
             mc:Ignorable="d"
             d:DesignWidth="800" d:DesignHeight="600"
             x:DataType="vm:DocumentViewModel" x:CompileBindings="True">

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- Toolbar -->
    <Border Grid.Row="0"
            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
            BorderThickness="0 0 0 1"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            Padding="6 4">
      <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

        <!-- Language selector -->
        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0 0 12 0">
          <TextBlock Text="Language:" VerticalAlignment="Center" FontSize="12" Opacity="0.7"/>
          <ComboBox x:Name="LanguageCombo"
                    MinWidth="130"
                    FontSize="12"
                    VerticalAlignment="Center"
                    VerticalContentAlignment="Center"/>
        </StackPanel>

        <!-- Editor options -->
        <ToggleButton x:Name="WordWrapToggle"
                      Content="Word Wrap"
                      FontSize="12"
                      VerticalAlignment="Center"
                      Margin="0 0 4 0"
                      Padding="8 3"/>
        <ToggleButton x:Name="ShowLineNumbersToggle"
                      Content="Line Numbers"
                      FontSize="12"
                      IsChecked="True"
                      VerticalAlignment="Center"
                      Margin="0 0 4 0"
                      Padding="8 3"/>
      </WrapPanel>
    </Border>

    <!-- Editor -->
    <AvalonEdit:TextEditor x:Name="Editor"
                           Grid.Row="1"
                           FontFamily="Cascadia Code,Consolas,Menlo,Monospace"
                           FontSize="14"
                           FontWeight="Light"
                           HorizontalScrollBarVisibility="Auto"
                           VerticalScrollBarVisibility="Visible"
                           Watermark="Start typing...">
      <AvalonEdit:TextEditor.ContextFlyout>
        <MenuFlyout>
          <MenuItem Header="Cut"       InputGesture="Ctrl+X" x:Name="MenuCut"/>
          <MenuItem Header="Copy"      InputGesture="Ctrl+C" x:Name="MenuCopy"/>
          <MenuItem Header="Paste"     InputGesture="Ctrl+V" x:Name="MenuPaste"/>
          <MenuItem Header="-"/>
          <MenuItem Header="Select All" InputGesture="Ctrl+A" x:Name="MenuSelectAll"/>
        </MenuFlyout>
      </AvalonEdit:TextEditor.ContextFlyout>
    </AvalonEdit:TextEditor>

    <!-- Status bar -->
    <Border Grid.Row="2"
            Padding="8 3"
            BorderThickness="0 1 0 0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
      <StackPanel Orientation="Horizontal" Spacing="16">
        <TextBlock x:Name="CaretPositionText" Text="Ln 1, Col 1" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
        <TextBlock x:Name="BreakpointCountText" Text="Breakpoints: 0" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
        <TextBlock x:Name="SelectedLanguageText" Text="C#" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
      </StackPanel>
    </Border>

  </Grid>
</UserControl>

