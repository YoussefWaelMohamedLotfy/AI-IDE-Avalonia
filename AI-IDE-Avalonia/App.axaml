<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:AI_IDE_Avalonia"
             xmlns:core="using:Dock.Model.Core"
             Name="Dock Avalonia Demo"
             x:Class="AI_IDE_Avalonia.App">

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Resources>

        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <ResourceInclude Source="avares://Dock.Avalonia.Themes.Fluent/Presets/Ide/Default.axaml" />

                <ResourceDictionary>
                    <ControlRecycling x:Key="ControlRecyclingKey" />
                </ResourceDictionary>

                <ResourceDictionary>
                    <ResourceDictionary.ThemeDictionaries>
                        <ResourceDictionary x:Key='Default'>
                            <Color x:Key="RegionColor">#FFFAFAFA</Color>
                            <Color x:Key="AcrylicFallbackColor">#E2E2E2</Color>
                        </ResourceDictionary>
                        <ResourceDictionary x:Key='Dark'>
                            <Color x:Key="RegionColor">#FF212121</Color>
                            <Color x:Key="AcrylicFallbackColor">#1F1F1F</Color>
                            <!-- Ribbon dark-mode overrides — keys must match RibbonTheme* tokens from DefaultGenericTokens.axaml -->
                            <SolidColorBrush x:Key="RibbonThemeChromeBackgroundBrush"          Color="#FF212121" />
                            <SolidColorBrush x:Key="RibbonThemeChromeBorderBrush"              Color="#3A3A3A" />
                            <SolidColorBrush x:Key="RibbonThemeSurfaceBrush"                   Color="#2D2D2D" />
                            <SolidColorBrush x:Key="RibbonThemeOverlayBrush"                   Color="#AA000000" />
                            <SolidColorBrush x:Key="RibbonThemeTopRowBackgroundBrush"          Color="#FF212121" />
                            <SolidColorBrush x:Key="RibbonThemeQuickAccessRowBackgroundBrush"  Color="#FF212121" />
                            <SolidColorBrush x:Key="RibbonThemeTabStripBackgroundBrush"        Color="#1C1C1C" />
                            <SolidColorBrush x:Key="RibbonThemeTabHeaderForegroundBrush"       Color="#E0E0E0" />
                            <SolidColorBrush x:Key="RibbonThemeTabHeaderForegroundDisabledBrush" Color="#606060" />
                            <SolidColorBrush x:Key="RibbonThemeTabHeaderBackgroundBrush"       Color="#00000000" />
                            <SolidColorBrush x:Key="RibbonThemeTabHeaderBackgroundPointerOverBrush" Color="#333333" />
                            <SolidColorBrush x:Key="RibbonThemeTabHeaderBackgroundSelectedBrush"   Color="#00000000" />
                            <SolidColorBrush x:Key="RibbonThemeTabHeaderBackgroundPressedBrush"    Color="#3D3D3D" />
                            <SolidColorBrush x:Key="RibbonThemeTabHeaderBorderBrush"              Color="#00000000" />
                            <SolidColorBrush x:Key="RibbonThemeTabHeaderBorderPointerOverBrush"   Color="#00000000" />
                            <SolidColorBrush x:Key="RibbonThemeTabHeaderBorderSelectedBrush"      Color="#00000000" />
                            <SolidColorBrush x:Key="RibbonThemeTabSelectedPipeBrush"           Color="#0F6CBD" />
                            <SolidColorBrush x:Key="RibbonThemeMinimizedDropDownBackgroundBrush" Color="#2D2D2D" />
                            <SolidColorBrush x:Key="RibbonThemeMinimizedDropDownBorderBrush"   Color="#0F6CBD" />
                            <SolidColorBrush x:Key="RibbonThemeBackstagePanelBackgroundBrush"  Color="#2D2D2D" />
                            <SolidColorBrush x:Key="RibbonThemeBackstagePanelBorderBrush"      Color="#3A3A3A" />
                            <SolidColorBrush x:Key="RibbonThemeAccentBrush"                    Color="#0F6CBD" />
                            <SolidColorBrush x:Key="RibbonThemePrimaryTextBrush"               Color="#F0F0F0" />
                            <SolidColorBrush x:Key="RibbonThemeMutedTextBrush"                 Color="#A0A0A0" />
                            <SolidColorBrush x:Key="RibbonThemePopupBorderBrush"               Color="#4A4A4A" />
                            <SolidColorBrush x:Key="RibbonThemePopupDividerBrush"              Color="#444444" />
                            <SolidColorBrush x:Key="RibbonThemeGroupSeparatorBrush"            Color="#444444" />
                            <SolidColorBrush x:Key="RibbonThemeMenuSurfaceBrush"               Color="#2D2D2D" />
                            <SolidColorBrush x:Key="RibbonThemeCommandSurfaceBrush"            Color="#2D2D2D" />
                            <SolidColorBrush x:Key="RibbonThemeCommandHoverBrush"              Color="#383838" />
                            <SolidColorBrush x:Key="RibbonThemeCommandPressedBrush"            Color="#454545" />
                            <SolidColorBrush x:Key="RibbonThemeCommandBorderBrush"             Color="#5A5A5A" />
                            <SolidColorBrush x:Key="RibbonThemeCommandDisabledTextBrush"       Color="#666666" />
                            <SolidColorBrush x:Key="RibbonThemeFileTabBrush"                   Color="#0F6CBD" />
                            <SolidColorBrush x:Key="RibbonThemeContextBandBrush"               Color="#1A3A57" />
                            <SolidColorBrush x:Key="RibbonThemeContextBandBorderBrush"         Color="#0F6CBD" />
                            <SolidColorBrush x:Key="RibbonThemeCheckedBrush"                   Color="#2A3F55" />
                            <SolidColorBrush x:Key="RibbonThemeHoverBrush"                     Color="#383838" />
                            <SolidColorBrush x:Key="RibbonThemeHoverBorderBrush"               Color="#5A5A5A" />
                        </ResourceDictionary>
                    </ResourceDictionary.ThemeDictionaries>
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>

        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>

        <FluentTheme />

        <StyleInclude Source="avares://RibbonControl.Core/Themes/Generic.axaml" />

        <DockFluentTheme DensityStyle="Normal" />
        <!-- <DockFluentTheme DensityStyle="Compact" /> -->

        <Style Selector="DockControl">
            <Setter Property="(ControlRecyclingDataTemplate.ControlRecycling)" Value="{StaticResource ControlRecyclingKey}" />
        </Style>

        <Style Selector="DocumentControl">
            <Setter Property="IconTemplate">
                <DataTemplate DataType="core:IDockable">
                    <PathIcon
                    Data="M5 1C3.89543 1 3 1.89543 3 3V13C3 14.1046 3.89543 15 5 15H11C12.1046 15 13 14.1046 13 13V5.41421C13 5.01639 12.842 4.63486 12.5607 4.35355L9.64645 1.43934C9.36514 1.15804 8.98361 1 8.58579 1H5ZM4 3C4 2.44772 4.44772 2 5 2H8V4.5C8 5.32843 8.67157 6 9.5 6H12V13C12 13.5523 11.5523 14 11 14H5C4.44772 14 4 13.5523 4 13V3ZM11.7929 5H9.5C9.22386 5 9 4.77614 9 4.5V2.20711L11.7929 5Z"
                    Width="16"
                    Height="16"
                    Margin="0"
                    Padding="0,0,2,0" />
                </DataTemplate>
            </Setter>
        </Style>

        <Style Selector="DocumentControl">
            <Setter Property="HeaderTemplate">
                <DataTemplate DataType="core:IDockable">
                    <TextBlock Text="{Binding Title}"
                               VerticalAlignment="Center"
                               Padding="2"  />
                </DataTemplate>
            </Setter>
        </Style>

        <Style Selector="ToolControl">
            <Setter Property="HeaderTemplate">
                <DataTemplate DataType="core:IDockable">
                    <TextBlock Text="{Binding Title}" Padding="2" />
                </DataTemplate>
            </Setter>
        </Style>

        <Style Selector="ToolChromeControl">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />

    </Application.Styles>

</Application>
